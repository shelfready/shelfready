# Postgres. Local dev: `npm run db:dev` serves PGlite on
# postgres://localhost:5433/postgres. On the VPS, compose injects
# DATABASE_URL pointing at the stack's postgres service (ADR-0008) —
# set POSTGRES_PASSWORD in deploy/.env there instead.
DATABASE_URL=postgres://user:password@host:5432/shelfready

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth (optional in dev; provider is skipped when unset)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Stripe — TEST keys only (getStripe() refuses live keys; WORKFLOW guardrail)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Observability: Claude API calls (M4 enrichment/audit) export OTel traces
# here — Otterscope locally (see README)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# Connector-credential encryption at rest (AES-256-GCM)
# Generate: openssl rand -hex 32
CREDENTIALS_KEY=

# Feed artifact storage: fs (default; ARTIFACTS_DIR=.artifacts) or s3 (R2)
ARTIFACT_STORE=fs
# R2 (when ARTIFACT_STORE=s3): endpoint like https://<account>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Claude enrichment (M4) — server-side only
ANTHROPIC_API_KEY=
# ENRICHMENT_MODEL=claude-opus-4-8
