# Postgres (Neon in prod/staging; `npm run db:dev` serves a local PGlite
# on postgres://localhost:5433/postgres for development)
DATABASE_URL=postgres://user:password@host:5432/shelfready

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# GitHub OAuth (optional in dev; provider is skipped when unset)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
